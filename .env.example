# MongoDB (required for auth)
MONGODB_URI=mongodb://127.0.0.1:27017/759-private-exchange
#
# Default Super Admin (after DB is reachable): npm run seed:superadmin
# → superadmin@gmail.com / 12345678 → login → /dashboard/superadmin
#
# Atlas: if `mongodb+srv://` fails with querySrv ECONNREFUSED, your network/DNS may block SRV
# lookups — use Atlas "Standard connection string" (mongodb://host1:27017,host2:27017/...) or
# fix DNS / allow your IP in Atlas → Network Access.

# JWT signing secret (required in production)
JWT_SECRET=change-me-to-a-long-random-string

# Vercel / production: profile avatars cannot live on serverless disk (public/uploads is ephemeral).
# In Vercel: Project → Storage → Blob → connect store — this adds BLOB_READ_WRITE_TOKEN to the project.
# Redeploy after the var exists. Name must be exactly BLOB_READ_WRITE_TOKEN (read/write), not read-only.
# On Vercel without this token, avatar upload returns 503. Local dev (no VERCEL): uses public/uploads/avatars.
# Optional local Blob: vercel env pull → .env.local with BLOB_READ_WRITE_TOKEN.

# Optional: canonical site URL (some deploys use for links in email, etc.)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Public /register is users only; admins are created from the superadmin dashboard.

# Optional: include OTP in API JSON in development (never enable in production)
# DEV_RETURN_OTP=true

# Email (optional — without these, OTPs are logged to the server console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="759 Private Exchange <noreply@example.com>"
